# ─── AGENTWALL ENTERPRISE CONFIG ──────────────────────────────────────────────
# SECURITY: Never commit real keys to version control.

# Core Identity
AGENTWALL_DOMAIN=localhost
AGENTWALL_ADMIN_PASSWORD=admin-password-change-me

# Auth (Secure by Default)
AGENTWALL_AUTH_ENABLED=1
AGENTWALL_API_KEYS=key-1,key-2,key-3
AGENTWALL_JWT_SECRET=change-this-in-production-1234567890

# Security Logic
# open: fail-safe (availability first) | closed: fail-secure (security first)
AGENTWALL_FAIL_MODE=closed
AGENTWALL_PIPELINE_TIMEOUT=5.0
# standard | strict | permissive
AGENTWALL_POLICY_PROFILE=standard

# Logging & Non-Repudiation
# 32-byte hex secret for HMAC-SHA256 log signing
AGENTWALL_HMAC_KEY=1234567890abcdef1234567890abcdef1234567890abcdef1234567890abc
AGENTWALL_KEY_ID=v2-enterprise-k1
AGENTWALL_DB=/data/db/agentwall.duckdb

# State Sync (Redis is required for horizontal scaling)
REDIS_URL=redis://:password-change-me@localhost:6379
REDIS_PASSWORD=password-change-me

# Observability
GRAFANA_PASSWORD=grafana-admin-change-me

# LLM Backends
ANTHROPIC_API_KEY=your-key-here
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=llama3.1
