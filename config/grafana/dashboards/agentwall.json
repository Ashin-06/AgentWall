      "options": { "orientation": "horizontal", "barWidth": 0.6 },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#c084fc", "mode": "fixed" } } }
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 12 },
      "id": 21,
      "title": "Tool Call Frequency",
      "type": "barchart",
      "targets": [{ "expr": "sort_desc(sum(agentwall_tool_calls_total) by (tool))", "legendFormat": "{{tool}}" }],
      "options": { "orientation": "horizontal", "barWidth": 0.6 },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#60a5fa", "mode": "fixed" } } }
    },

    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 19 },
      "id": 3,
      "title": "Injection Score Distribution (p50 / p95 / p99)",
      "type": "timeseries",
      "targets": [
        { "expr": "agentwall_injection_score{quantile=\"0.5\"}", "legendFormat": "p50" },
        { "expr": "agentwall_injection_score{quantile=\"0.95\"}", "legendFormat": "p95" },
        { "expr": "agentwall_injection_score{quantile=\"0.99\"}", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 1, "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f09999", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5dcaa5", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
