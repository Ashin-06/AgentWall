          { "matcher": { "id": "byName", "options": "AUDIT" },  "properties": [{ "id": "color", "value": { "fixedColor": "#f0c875", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "PERMIT" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5dcaa5", "mode": "fixed" } }] }
