      "type": "timeseries",
      "targets": [
        { "expr": "agentwall_anomaly_score{quantile=\"0.95\"}", "legendFormat": "p95 anomaly" },
        { "expr": "agentwall_anomaly_score{quantile=\"0.5\"}",  "legendFormat": "p50 anomaly" }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 1, "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p95 anomaly" }, "properties": [{ "id": "color", "value": { "fixedColor": "#fb923c", "mode": "fixed" } }] }
        ]
      }
    },

    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 26 },
      "id": 23,
      "title": "Blocks per Agent (Top Offenders)",
      "type": "barchart",
      "targets": [{ "expr": "sort_desc(sum(agentwall_agent_blocks_total) by (agent))", "legendFormat": "{{agent}}" }],
      "options": { "orientation": "horizontal" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#f09999", "mode": "fixed" } } }
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 26 },
      "id": 6,
